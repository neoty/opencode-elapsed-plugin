{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "opencode-elapsed-plugin",
  "version": "1.0.0",
  "description": "A small OpenCode TUI plugin that shows prompt-side elapsed activity timers.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tui": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepack": "npm run test && npm run build"
  },
  "keywords": [
    "opencode",
    "plugin",
    "tui",
    "elapsed",
    "timer"
  ],
  "peerDependencies": {
    "@opentui/solid": "^0.2.6",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "1.14.46",
    "@opentui/solid": "0.2.6",
    "@types/node": "24.12.2",
    "solid-js": "1.9.12",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
